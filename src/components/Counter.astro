---
interface Props {
  initial?: number;
}

const { initial = 0 } = Astro.props;
const id = `counter-${Math.random().toString(36).slice(2, 8)}`;
---

<div id={id} class="flex flex-col items-center gap-4">
  <p class="text-sm font-medium tracking-widest text-gray-500 uppercase">Interactive Counter</p>
  <div class="flex items-center gap-6">
    <button
      data-action="decrement"
      class="flex h-10 w-10 items-center justify-center rounded-full border border-gray-700 text-gray-400 transition-colors hover:border-gray-500 hover:text-white"
      aria-label="Decrement"
    >
      −
    </button>
    <span data-count class="w-16 text-center text-5xl font-bold tabular-nums" aria-live="polite">
      {initial}
    </span>
    <button
      data-action="increment"
      class="flex h-10 w-10 items-center justify-center rounded-full border border-gray-700 text-gray-400 transition-colors hover:border-gray-500 hover:text-white"
      aria-label="Increment"
    >
      +
    </button>
  </div>
  <button
    data-action="reset"
    class="text-xs text-gray-600 transition-colors hover:text-gray-400"
    aria-label="Reset counter"
  >
    reset
  </button>
</div>

<script define:vars={{ id, initial }}>
  const root = document.getElementById(id);
  if (root) {
    let count = initial;
    const display = root.querySelector("[data-count]");

    root.addEventListener("click", (e) => {
      const action = e.target.closest("[data-action]")?.dataset.action;
      if (action === "increment") count++;
      else if (action === "decrement") count--;
      else if (action === "reset") count = initial;
      else return;
      if (display) display.textContent = String(count);
    });
  }
</script>
