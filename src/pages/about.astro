---
import MarketingLayout from "@/layouts/MarketingLayout.astro";

const techCards = [
  {
    name: "Astro",
    role: "Static site framework",
    detail:
      "Every marketing page is a zero-JS static HTML file. Only the editor page ships JavaScript — and only as much as the interactive islands need.",
  },
  {
    name: "SolidJS",
    role: "Interactive islands",
    detail:
      "The editor form, file upload, and preview panel are SolidJS components. They run only in the browser, never on a server.",
  },
  {
    name: "pdfmake",
    role: "PDF generation",
    detail:
      "Resume export is handled entirely client-side with pdfmake. The PDF is generated in your browser tab and downloaded directly — no server involved.",
  },
];
---

<MarketingLayout
  title="About — Tailory"
  description="Tailory is a privacy-first, fully client-side resume editor. Everything runs in your browser. No server ever touches your data."
>
  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-8 pb-16 pt-24">
    <p class="mb-6 text-xs font-medium uppercase tracking-[0.25em] text-[#a0b8ab]">About</p>
    <h1
      class="max-w-2xl leading-[1.1] text-[#0e2418]"
      style="font-family: 'Lora', Georgia, serif; font-size: clamp(36px, 4.5vw, 56px); font-weight: 700"
    >
      A resume editor that respects you.
    </h1>
    <div class="mt-8 h-px w-20 bg-[#ccddd4]"></div>
  </section>

  <!-- Mission -->
  <section class="mx-auto max-w-6xl px-8 pb-24">
    <div class="max-w-2xl">
      <p class="mb-6 text-lg leading-relaxed text-[#3d6650]">
        Tailory was built on a simple principle: your resume is yours. It contains your career
        history, your contact details, your professional narrative — and none of that should pass
        through a third-party server just because you want to edit a document.
      </p>
      <p class="mb-6 text-lg leading-relaxed text-[#3d6650]">
        Every feature in Tailory runs entirely in your browser. File extraction, text parsing, live
        preview rendering, PDF generation — all of it happens locally. When you close the tab,
        nothing leaves your device. There is no Tailory backend. There are no accounts. There is no
        telemetry.
      </p>
      <p class="text-lg leading-relaxed text-[#3d6650]">
        Privacy-first is not a marketing claim here — it is a structural fact. There is no server to
        breach. No database to leak. No company to sell your data. Just a web app that does its job
        and gets out of the way.
      </p>
    </div>
  </section>

  <!-- Divider -->
  <div class="mx-auto max-w-6xl border-t border-[#ccddd4] px-8"></div>

  <!-- How it's built -->
  <section class="mx-auto max-w-6xl px-8 py-24">
    <p class="mb-12 text-xs font-medium uppercase tracking-[0.25em] text-[#a0b8ab]">
      How it's built
    </p>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      {
        techCards.map((card) => (
          <div class="rounded-xl border border-[#ccddd4] bg-white p-8">
            <p
              class="mb-1 text-lg font-bold text-[#0e2418]"
              style="font-family: 'Lora', Georgia, serif"
            >
              {card.name}
            </p>
            <p class="mb-4 text-xs font-medium uppercase tracking-[0.15em] text-[#a0b8ab]">
              {card.role}
            </p>
            <p class="text-sm leading-relaxed text-[#3d6650]">{card.detail}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Divider -->
  <div class="mx-auto max-w-6xl border-t border-[#ccddd4] px-8"></div>

  <!-- Open source -->
  <section class="mx-auto max-w-6xl px-8 py-24">
    <div class="flex flex-col gap-10 md:flex-row md:items-start">
      <div class="max-w-xl">
        <p class="mb-6 text-xs font-medium uppercase tracking-[0.25em] text-[#a0b8ab]">
          Open source
        </p>
        <h2
          class="mb-5 leading-snug text-[#0e2418]"
          style="font-family: 'Lora', Georgia, serif; font-size: clamp(22px, 2.5vw, 32px); font-weight: 700"
        >
          MIT licensed. Free forever.
        </h2>
        <p class="mb-6 text-base leading-relaxed text-[#3d6650]">
          Tailory is fully open source under the MIT licence. You can inspect every line of code,
          self-host it, fork it, or contribute improvements. The source is on GitHub — issues, PRs,
          and discussions are all welcome.
        </p>
        <a
          href="https://github.com/abijith-suresh/tailory"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border border-[#1d6648] px-6 py-2.5 text-sm font-medium text-[#1d6648] transition-colors hover:bg-[#1d6648] hover:text-white"
        >
          View on GitHub ↗
        </a>
      </div>
      <!-- JSON Resume standard -->
      <div class="rounded-xl border border-[#ccddd4] bg-white p-8 md:flex-1">
        <p class="mb-3 text-xs font-medium uppercase tracking-[0.15em] text-[#a0b8ab]">Built on</p>
        <p
          class="mb-3 text-lg font-bold text-[#0e2418]"
          style="font-family: 'Lora', Georgia, serif"
        >
          JSON Resume
        </p>
        <p class="text-sm leading-relaxed text-[#3d6650]">
          Tailory stores resume data using the open{" "}
          <a
            href="https://jsonresume.org"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#1d6648] underline underline-offset-2 hover:no-underline"
          >
            JSON Resume
          </a>{" "}
          standard schema. This means your data is portable — not locked into a proprietary format. Any
          tool that speaks JSON Resume can read what Tailory saves.
        </p>
      </div>
    </div>
  </section>
</MarketingLayout>
