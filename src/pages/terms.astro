---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
---

<MarketingLayout
  title="Terms of Service — Tailory"
  description="Tailory's terms of service. MIT licensed, open source, no warranty."
>
  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-8 pb-12 pt-24">
    <p class="mb-6 text-xs font-medium uppercase tracking-[0.25em] text-[#a0b8ab]">Legal</p>
    <h1
      class="max-w-2xl leading-[1.1] text-[#0e2418]"
      style="font-family: 'Lora', Georgia, serif; font-size: clamp(36px, 4.5vw, 56px); font-weight: 700"
    >
      Terms of Service
    </h1>
    <div class="mt-8 h-px w-20 bg-[#ccddd4]"></div>
  </section>

  <!-- Content -->
  <section class="mx-auto max-w-3xl px-8 pb-24">
    <!-- License -->
    <div class="mb-12 border-t border-[#ccddd4] pt-10">
      <h2 class="mb-4 text-xl font-bold text-[#0e2418]" style="font-family: 'Lora', Georgia, serif">
        Licence
      </h2>
      <p class="mb-4 text-base leading-relaxed text-[#3d6650]">
        Tailory is released under the{" "}
        <a
          href="https://opensource.org/licenses/MIT"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[#1d6648] underline underline-offset-2 hover:no-underline"
        >
          MIT Licence
        </a>. You are free to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
        copies of the software, subject to the conditions of the MIT Licence.
      </p>
      <div
        class="rounded-lg border border-[#ccddd4] bg-[#f4f8f5] px-5 py-4 font-mono text-sm text-[#3d6650]"
      >
        <p>Copyright © 2025 Tailory contributors</p>
        <p class="mt-2">
          Permission is hereby granted, free of charge, to any person obtaining a copy of this
          software and associated documentation files, to deal in the software without restriction,
          including without limitation the rights to use, copy, modify, merge, publish, distribute,
          sublicense, and/or sell copies of the software.
        </p>
      </div>
    </div>

    <!-- No warranty -->
    <div class="mb-12 border-t border-[#ccddd4] pt-10">
      <h2 class="mb-4 text-xl font-bold text-[#0e2418]" style="font-family: 'Lora', Georgia, serif">
        No warranty
      </h2>
      <p class="text-base leading-relaxed text-[#3d6650]">
        The software is provided "as is", without warranty of any kind, express or implied,
        including but not limited to the warranties of merchantability, fitness for a particular
        purpose, and non-infringement. Your use of Tailory is at your own risk.
      </p>
    </div>

    <!-- No liability -->
    <div class="mb-12 border-t border-[#ccddd4] pt-10">
      <h2 class="mb-4 text-xl font-bold text-[#0e2418]" style="font-family: 'Lora', Georgia, serif">
        Limitation of liability
      </h2>
      <p class="text-base leading-relaxed text-[#3d6650]">
        In no event shall the authors or copyright holders be liable for any claim, damages, or
        other liability — whether in an action of contract, tort, or otherwise — arising from, out
        of, or in connection with the software or the use or other dealings in the software.
      </p>
    </div>

    <!-- Source code -->
    <div class="mb-12 border-t border-[#ccddd4] pt-10">
      <h2 class="mb-4 text-xl font-bold text-[#0e2418]" style="font-family: 'Lora', Georgia, serif">
        Source code
      </h2>
      <p class="text-base leading-relaxed text-[#3d6650]">
        The complete source code for Tailory is publicly available at{" "}
        <a
          href="https://github.com/abijith-suresh/tailory"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[#1d6648] underline underline-offset-2 hover:no-underline"
        >
          github.com/abijith-suresh/tailory
        </a>. The repository is the authoritative reference for the licence terms.
      </p>
    </div>

    <!-- Changes -->
    <div class="mb-12 border-t border-[#ccddd4] pt-10">
      <h2 class="mb-4 text-xl font-bold text-[#0e2418]" style="font-family: 'Lora', Georgia, serif">
        Changes to these terms
      </h2>
      <p class="text-base leading-relaxed text-[#3d6650]">
        These terms may be updated from time to time. The latest version is always available in the
        GitHub repository. Continued use of Tailory after changes are published constitutes
        acceptance of the updated terms.
      </p>
    </div>

    <!-- Effective date -->
    <div class="border-t border-[#ccddd4] pt-10">
      <p class="text-sm text-[#a0b8ab]">Effective date: January 2025</p>
    </div>
  </section>
</MarketingLayout>
