---
import Layout from "@/layouts/Layout.astro";

const features = [
  {
    n: "01",
    term: "PDF & DOCX Upload",
    def: "Drop any resume format — Tailory handles the text extraction entirely in your browser.",
  },
  {
    n: "02",
    term: "Auto-Parsing",
    def: "Heuristic parsing maps raw text into structured JSON Resume fields automatically.",
  },
  {
    n: "03",
    term: "Live Preview",
    def: "See your resume rendered in real time as you edit — no save, no reload.",
  },
  {
    n: "04",
    term: "Three Templates",
    def: "Modern, Minimal, and Compact ATS — each tuned for a different industry or context.",
  },
  {
    n: "05",
    term: "ATS-Safe Export",
    def: "Machine-readable PDFs with no images or tables to confuse applicant tracking systems.",
  },
  {
    n: "06",
    term: "Draft Storage",
    def: "Your work saves automatically to IndexedDB in your browser — never to a server.",
  },
];

const manifesto = [
  "Your resume is private. It should stay that way.",
  "No account. No upload. No server ever sees your data.",
  "Open source. Free. Always.",
];

const steps = [
  { title: "Upload", desc: "Drop your existing PDF or DOCX, or begin from a blank form." },
  { title: "Edit", desc: "Refine every field in a structured, section-by-section editor." },
  { title: "Export", desc: "Download a polished, ATS-compatible PDF in one click." },
];
---

<Layout
  title="Tailory — Parchment"
  description="A fully client-side resume editor. No server, no account, no data leaves your device."
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div
    class="min-h-screen bg-[#f0e8d8] text-[#2e1b14]"
    style="font-family: 'Source Serif 4', Georgia, serif"
  >
    <!-- Nav -->
    <header class="border-b border-[#c8a882]">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-8 py-5">
        <span
          class="text-2xl font-bold tracking-tight text-[#6b2737]"
          style="font-family: 'Playfair Display', Georgia, serif"
        >
          Tailory
        </span>
        <a
          href="https://github.com/abijith-suresh/tailory"
          target="_blank"
          rel="noopener noreferrer"
          class="text-base text-[#8a6650] transition-colors hover:text-[#6b2737]"
        >
          GitHub ↗
        </a>
      </nav>
    </header>

    <!-- Hero — Split layout -->
    <section class="mx-auto max-w-6xl px-8 py-24">
      <div class="grid grid-cols-1 gap-16 lg:grid-cols-5">
        <!-- Left: headline -->
        <div class="lg:col-span-3">
          <p class="mb-8 text-xs uppercase tracking-[0.2em] text-[#8a6650]">
            Client-side resume editor
          </p>
          <h1
            class="mb-8 leading-[1.05] text-[#2e1b14]"
            style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(48px, 6.5vw, 82px); font-style: italic; font-weight: 700"
          >
            Resume editing<br />
            as it should be —<br />
            <span style="color: #6b2737">entirely yours.</span>
          </h1>
          <div class="mb-8 h-px w-16 bg-[#6b2737]"></div>
          <p class="mb-10 max-w-md text-xl leading-relaxed text-[#8a6650]">
            Upload a PDF or DOCX, edit every field, export an ATS-safe PDF. No account, no server,
            no data leaves your browser.
          </p>
          <a
            href="/editor"
            class="inline-block bg-[#6b2737] px-8 py-3 text-base text-[#f0e8d8] transition-opacity hover:opacity-90"
          >
            Open the editor →
          </a>
        </div>

        <!-- Right: manifesto panel -->
        <div class="border-l border-[#c8a882] pl-10 lg:col-span-2">
          <p
            class="mb-8 text-xs uppercase tracking-[0.2em] text-[#8a6650]"
            style="font-family: 'Playfair Display', Georgia, serif"
          >
            Our position
          </p>
          <ul class="space-y-8">
            {
              manifesto.map((item) => (
                <li class="text-xl leading-snug text-[#2e1b14]">
                  <span class="text-[#6b2737]">&ldquo;</span>
                  {item}
                  <span class="text-[#6b2737]">&rdquo;</span>
                </li>
              ))
            }
          </ul>
          <div class="mt-10 border-t border-[#c8a882] pt-8">
            <p class="text-base text-[#8a6650]">
              No telemetry. No cloud sync. Your data never leaves your browser.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="mx-auto max-w-6xl border-t border-[#c8a882] px-8"></div>

    <!-- Features — numbered editorial items -->
    <section class="mx-auto max-w-6xl px-8 py-24">
      <p class="mb-16 text-xs uppercase tracking-[0.2em] text-[#8a6650]">What it does</p>
      <div class="space-y-0">
        {
          features.map((f) => (
            <div class="flex items-start gap-10 border-b border-[#c8a882] py-8 first:border-t">
              <span
                class="mt-1 min-w-[2.5rem] text-sm text-[#8a6650]"
                style="font-family: 'Playfair Display', Georgia, serif"
              >
                {f.n}
              </span>
              <div class="grid flex-1 grid-cols-1 gap-2 md:grid-cols-3">
                <h3
                  class="text-xl font-bold text-[#2e1b14] md:col-span-1"
                  style="font-family: 'Playfair Display', Georgia, serif"
                >
                  {f.term}
                </h3>
                <p class="text-base leading-relaxed text-[#8a6650] md:col-span-2">{f.def}</p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Divider -->
    <div class="mx-auto max-w-6xl border-t border-[#c8a882] px-8"></div>

    <!-- How it works -->
    <section class="mx-auto max-w-6xl px-8 py-24">
      <p class="mb-16 text-xs uppercase tracking-[0.2em] text-[#8a6650]">Three steps</p>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
        {
          steps.map((s, i) => (
            <div>
              <p class="mb-3 text-xs uppercase tracking-[0.2em] text-[#6b2737]">Step {i + 1}</p>
              <h3
                class="mb-3 text-2xl font-bold text-[#2e1b14]"
                style="font-family: 'Playfair Display', Georgia, serif"
              >
                {s.title}
              </h3>
              <div class="mb-4 h-px w-10 bg-[#6b2737]" />
              <p class="text-base leading-relaxed text-[#8a6650]">{s.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Privacy callout — inverted -->
    <div class="bg-[#6b2737]">
      <div class="mx-auto max-w-6xl px-8 py-20 text-center">
        <h2
          class="mb-5 leading-tight text-[#f0e8d8]"
          style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(28px, 3.5vw, 46px); font-style: italic; font-weight: 700"
        >
          Your data never leaves your browser.
        </h2>
        <p class="mx-auto max-w-md text-lg leading-relaxed text-[#e0c8b4]">
          Tailory is a fully client-side tool. There is no server to send your resume to, because
          there is no server.
        </p>
      </div>
    </div>

    <!-- Footer -->
    <footer class="mx-auto flex max-w-6xl items-center justify-between px-8 py-10">
      <p class="text-sm text-[#8a6650]">© 2025 Tailory — MIT licensed</p>
      <nav class="flex gap-8 text-sm">
        <a href="/features" class="text-[#8a6650] transition-colors hover:text-[#6b2737]"
          >Features</a
        >
        <a href="/about" class="text-[#8a6650] transition-colors hover:text-[#6b2737]">About</a>
        <a href="/faq" class="text-[#8a6650] transition-colors hover:text-[#6b2737]">FAQ</a>
      </nav>
    </footer>
  </div>
</Layout>
