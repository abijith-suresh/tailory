---
import Layout from "@/layouts/Layout.astro";

const features = [
  {
    term: "PDF & DOCX Upload",
    def: "Drop any resume format — Tailory handles text extraction entirely in your browser.",
  },
  {
    term: "Auto-Parsing",
    def: "Heuristic parsing maps raw text into structured JSON Resume fields automatically.",
  },
  {
    term: "Live Preview",
    def: "See your resume rendered in real time as you make edits — no save required.",
  },
  {
    term: "Three Templates",
    def: "Modern, Minimal, and Compact ATS — each optimised for a different context.",
  },
  {
    term: "ATS-Safe Export",
    def: "Machine-readable PDFs with no images or tables to trip up applicant tracking systems.",
  },
  {
    term: "Draft Storage",
    def: "Your work saves automatically to your browser's IndexedDB — never to a server.",
  },
];

const steps = [
  {
    n: "01",
    title: "Upload",
    desc: "Drop your existing PDF or DOCX resume, or begin from a blank form.",
  },
  {
    n: "02",
    title: "Edit",
    desc: "Refine every field in a calm structured editor. No formatting fights.",
  },
  { n: "03", title: "Export", desc: "Download a polished, ATS-compatible PDF in one click." },
];

const tabs = ["Basics", "Summary", "Work", "Education"];
const formFields = [
  { label: "Full name", val: "Alex Johnson" },
  { label: "Email", val: "alex@example.com" },
  { label: "Location", val: "San Francisco, CA" },
];
---

<Layout
  title="Tailory — Fog"
  description="A fully client-side resume editor. No server, no account, no data leaves your device."
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,400;0,500;0,600;0,700;0,800;1,700&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div
    class="min-h-screen bg-[#f8f7f5] text-[#2a2825]"
    style="font-family: 'Figtree', system-ui, sans-serif"
  >
    <!-- Nav -->
    <header class="border-b border-[#e2dfd9]">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-8 py-5">
        <span class="text-xl font-bold tracking-tight text-[#2a2825]">Tailory</span>
        <a
          href="https://github.com/abijith-suresh/tailory"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-[#867f77] transition-colors hover:text-[#6d5ace]"
        >
          GitHub ↗
        </a>
      </nav>
    </header>

    <!-- Hero -->
    <section class="mx-auto max-w-6xl px-8 pb-20 pt-24">
      <p class="mb-8 text-xs font-medium uppercase tracking-[0.25em] text-[#c4bfb8]">
        Client-side resume editor
      </p>
      <h1
        class="mb-8 max-w-3xl leading-[1.0] tracking-tight text-[#2a2825]"
        style="font-size: clamp(52px, 6.5vw, 84px); font-weight: 800; font-style: italic"
      >
        Your resume,<br />
        <span style="color: #6d5ace; font-style: italic">your browser,</span><br />
        your call.
      </h1>
      <div class="mb-10 h-px w-16 bg-[#e2dfd9]"></div>
      <p class="mb-10 max-w-xl text-lg leading-relaxed text-[#867f77]">
        Upload a PDF or DOCX, edit every field in a focused interface, and export an ATS-safe PDF —
        without sending a single byte to a server.
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a
          href="/editor"
          class="inline-block rounded-lg bg-[#6d5ace] px-7 py-3 text-sm font-semibold text-white transition-colors hover:bg-[#5b47b0]"
        >
          Open the editor →
        </a>
        <div class="flex flex-wrap gap-3">
          {
            ["No account", "Local only", "Open source"].map((chip) => (
              <span class="rounded-full border border-[#e2dfd9] bg-white px-4 py-1.5 text-xs font-medium text-[#867f77]">
                {chip}
              </span>
            ))
          }
        </div>
      </div>
    </section>

    <!-- App Preview Mockup -->
    <section class="mx-auto max-w-6xl px-8 pb-24">
      <p class="mb-5 text-xs font-medium uppercase tracking-[0.2em] text-[#c4bfb8]">
        Editor preview
      </p>
      <div class="overflow-hidden rounded-2xl border border-[#e2dfd9] shadow-lg shadow-[#6d5ace]/5">
        <!-- Top bar -->
        <div class="flex items-center border-b border-[#e2dfd9] bg-white px-4 py-2.5">
          <span class="mr-6 text-sm font-bold text-[#2a2825]">Tailory</span>
          <div class="flex">
            {
              tabs.map((tab, i) => (
                <div
                  class:list={[
                    "border-b-2 px-4 py-2 text-xs font-semibold transition-colors",
                    i === 0
                      ? "border-[#6d5ace] text-[#6d5ace]"
                      : "border-transparent text-[#c4bfb8]",
                  ]}
                >
                  {tab}
                </div>
              ))
            }
          </div>
          <div class="ml-auto">
            <span class="rounded-md bg-[#6d5ace] px-3 py-1 text-xs font-semibold text-white"
              >Export PDF</span
            >
          </div>
        </div>
        <!-- Split pane -->
        <div class="flex" style="height: 260px">
          <!-- Left: Editor panel -->
          <div class="w-1/2 overflow-hidden border-r border-[#e2dfd9] bg-[#f8f7f5] p-5">
            <p class="mb-4 text-[10px] font-semibold uppercase tracking-widest text-[#c4bfb8]">
              Basics
            </p>
            {
              formFields.map((field) => (
                <div class="mb-3">
                  <p class="mb-1 text-[11px] font-semibold text-[#867f77]">{field.label}</p>
                  <div class="rounded-md border border-[#e2dfd9] bg-white px-3 py-2 text-xs text-[#2a2825]">
                    {field.val}
                  </div>
                </div>
              ))
            }
          </div>
          <!-- Right: Preview panel -->
          <div class="w-1/2 bg-[#f8f7f5] p-5">
            <p class="mb-4 text-[10px] font-semibold uppercase tracking-widest text-[#c4bfb8]">
              Preview
            </p>
            <div class="rounded-lg border border-[#e2dfd9] bg-white p-4">
              <div class="mb-2 h-3 w-28 rounded bg-[#6d5ace]/20"></div>
              <div class="mb-4 h-2 w-20 rounded bg-[#e2dfd9]"></div>
              <div class="mb-1.5 h-2 w-full rounded bg-[#e2dfd9]"></div>
              <div class="mb-1.5 h-2 w-5/6 rounded bg-[#e2dfd9]"></div>
              <div class="mb-4 h-2 w-4/5 rounded bg-[#e2dfd9]"></div>
              <div class="mb-1 h-2 w-16 rounded bg-[#6d5ace]/40"></div>
              <div class="mb-1.5 h-2 w-full rounded bg-[#e2dfd9]"></div>
              <div class="h-2 w-3/4 rounded bg-[#e2dfd9]"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="mx-auto max-w-6xl border-t border-[#e2dfd9] px-8"></div>

    <!-- Features — 3-column soft cards -->
    <section class="mx-auto max-w-6xl px-8 py-24">
      <p class="mb-16 text-xs font-semibold uppercase tracking-[0.2em] text-[#c4bfb8]">
        What it does
      </p>
      <dl class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          features.map((f) => (
            <div class="rounded-xl border border-[#e2dfd9] bg-white p-6">
              <dt class="mb-2 text-sm font-bold text-[#2a2825]">{f.term}</dt>
              <dd class="text-sm leading-relaxed text-[#867f77]">{f.def}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    <!-- Divider -->
    <div class="mx-auto max-w-6xl border-t border-[#e2dfd9] px-8"></div>

    <!-- How it works -->
    <section class="mx-auto max-w-6xl px-8 py-24">
      <p class="mb-16 text-xs font-semibold uppercase tracking-[0.2em] text-[#c4bfb8]">
        How it works
      </p>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
        {
          steps.map((s) => (
            <div>
              <p class="mb-4 font-extrabold leading-none text-[#e2dfd9]" style="font-size: 3.5rem">
                {s.n}
              </p>
              <h3 class="mb-3 text-lg font-bold text-[#2a2825]">{s.title}</h3>
              <p class="text-sm leading-relaxed text-[#867f77]">{s.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Privacy callout -->
    <div class="rounded-none bg-[#6d5ace]">
      <div class="mx-auto max-w-6xl px-8 py-20">
        <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-[#a79de0]">Privacy</p>
        <h2
          class="mb-5 max-w-3xl font-bold leading-tight text-white"
          style="font-size: clamp(28px, 3.5vw, 46px)"
        >
          Your resume is your business. We have no way of seeing it.
        </h2>
        <p class="max-w-lg text-base leading-relaxed text-[#c4bcf0]">
          No telemetry. No cloud sync. No accounts required. Tailory runs entirely in your browser —
          your data stays exactly where it belongs.
        </p>
      </div>
    </div>

    <!-- Footer -->
    <footer class="mx-auto flex max-w-6xl items-center justify-between px-8 py-10">
      <p class="text-sm text-[#c4bfb8]">© 2025 Tailory — MIT licensed</p>
      <nav class="flex gap-8 text-sm">
        <a href="/features" class="text-[#867f77] transition-colors hover:text-[#6d5ace]"
          >Features</a
        >
        <a href="/about" class="text-[#867f77] transition-colors hover:text-[#6d5ace]">About</a>
        <a href="/faq" class="text-[#867f77] transition-colors hover:text-[#6d5ace]">FAQ</a>
      </nav>
    </footer>
  </div>
</Layout>
