---
import Layout from "@/layouts/Layout.astro";

const features = [
  { name: "PDF & DOCX Upload", desc: "Any format, extracted locally — nothing sent anywhere." },
  { name: "Auto-Parsing", desc: "Structured fields extracted from raw text, automatically." },
  { name: "Live Preview", desc: "Your resume, rendered in real time as you edit." },
  { name: "Three Templates", desc: "Modern, Minimal, Compact ATS — switch at any time." },
  { name: "ATS-Safe Export", desc: "Machine-readable PDFs, no images or tables." },
  { name: "Draft Storage", desc: "Auto-saved to IndexedDB. Local, always." },
];

const steps = [
  {
    n: "I",
    title: "Upload",
    desc: "Drop your PDF or DOCX, or begin from a blank form. Text extraction is instant and local.",
  },
  {
    n: "II",
    title: "Edit",
    desc: "Refine each section at your own pace. The preview updates as you type.",
  },
  {
    n: "III",
    title: "Export",
    desc: "One click. A polished, ATS-compatible PDF downloads to your device.",
  },
];
---

<Layout
  title="Tailory — Dusk"
  description="A fully client-side resume editor. No server, no account, no data leaves your device."
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@1,9..144,300;1,9..144,400&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div
    class="min-h-screen bg-[#0b0e1a] text-[#8a96b4]"
    style="font-family: 'DM Sans', system-ui, sans-serif"
  >
    <!-- Nav -->
    <header class="border-b border-[#141828]">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-8 py-5">
        <span
          class="text-2xl text-[#e2d0a8]"
          style="font-family: 'Fraunces', Georgia, serif; font-style: italic; font-weight: 300"
        >
          Tailory
        </span>
        <a
          href="https://github.com/abijith-suresh/tailory"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-[#3a4460] transition-colors hover:text-[#e2d0a8]"
        >
          GitHub ↗
        </a>
      </nav>
    </header>

    <!-- Hero — right-aligned offset headline -->
    <section class="mx-auto max-w-6xl px-8 pb-24 pt-24">
      <div class="grid grid-cols-1 gap-16 lg:grid-cols-12">
        <!-- Left: privacy manifesto quote -->
        <div class="flex flex-col justify-center lg:col-span-4">
          <p class="mb-6 text-xs uppercase tracking-[0.2em] text-[#3a4460]">Privacy</p>
          <blockquote
            class="border-l border-[#e2d0a8] pl-6 text-xl leading-relaxed text-[#6b7898]"
            style="font-family: 'Fraunces', Georgia, serif; font-style: italic; font-weight: 300"
          >
            No server has ever seen your resume. None ever will.
          </blockquote>
          <div class="mt-8 border-t border-[#141828] pt-8">
            <p class="text-sm leading-relaxed text-[#3a4460]">
              Tailory is fully client-side. Upload, edit, export — entirely in your browser.
            </p>
          </div>
        </div>

        <!-- Right: large headline -->
        <div class="lg:col-span-8 lg:text-right">
          <p class="mb-8 text-xs uppercase tracking-[0.2em] text-[#3a4460] lg:text-right">
            Client-side resume editor
          </p>
          <h1
            class="mb-8 leading-[0.95] text-[#e2d0a8]"
            style="font-family: 'Fraunces', Georgia, serif; font-size: clamp(52px, 7.5vw, 92px); font-style: italic; font-weight: 400"
          >
            Resume editing<br />
            by lamplight —<br />
            <span style="color: #c4b48a">just you and your words.</span>
          </h1>
          <a
            href="/editor"
            class="inline-block border border-[#e2d0a8] px-8 py-3 text-sm text-[#e2d0a8] transition-all hover:bg-[#e2d0a8] hover:text-[#0b0e1a]"
          >
            Open the editor →
          </a>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="mx-auto max-w-6xl border-t border-[#141828] px-8"></div>

    <!-- Features — minimal, one-line each -->
    <section class="mx-auto max-w-6xl px-8 py-24">
      <p class="mb-16 text-xs uppercase tracking-[0.2em] text-[#3a4460]">What it does</p>
      <div class="grid grid-cols-1 gap-0 md:grid-cols-2">
        {
          features.map((f) => (
            <div class="flex items-baseline gap-6 border-b border-[#141828] py-6 first:border-t md:[&:nth-child(2)]:border-t">
              <span class="min-w-[6px] text-[#e2d0a8]">·</span>
              <div>
                <span class="mr-3 text-base font-medium text-[#c4b48a]">{f.name}</span>
                <span class="text-base text-[#3a4460]">{f.desc}</span>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Divider -->
    <div class="mx-auto max-w-6xl border-t border-[#141828] px-8"></div>

    <!-- How it works — large numeral + horizontal prose -->
    <section class="mx-auto max-w-6xl px-8 py-24">
      <p class="mb-16 text-xs uppercase tracking-[0.2em] text-[#3a4460]">How it works</p>
      <div class="space-y-16">
        {
          steps.map((s) => (
            <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:items-start">
              <div class="md:col-span-1">
                <span
                  class="leading-none text-[#141828]"
                  style="font-family: 'Fraunces', Georgia, serif; font-size: 3.5rem; font-style: italic; font-weight: 300"
                >
                  {s.n}
                </span>
              </div>
              <div class="md:col-span-3">
                <h3
                  class="text-xl text-[#e2d0a8]"
                  style="font-family: 'Fraunces', Georgia, serif; font-style: italic; font-weight: 300"
                >
                  {s.title}
                </h3>
              </div>
              <div class="md:col-span-8">
                <div class="mb-4 mt-2 h-px w-full bg-[#141828] md:hidden" />
                <p class="text-base leading-relaxed text-[#3a4460]">{s.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Privacy callout — understated -->
    <div class="border-y border-[#141828] bg-[#080b14]">
      <div class="mx-auto max-w-6xl px-8 py-20">
        <h2
          class="mb-5 max-w-2xl leading-tight text-[#e2d0a8]"
          style="font-family: 'Fraunces', Georgia, serif; font-size: clamp(28px, 3.5vw, 48px); font-style: italic; font-weight: 300"
        >
          Your resume is yours. Completely.
        </h2>
        <p class="max-w-lg text-base leading-relaxed text-[#3a4460]">
          No telemetry, no cloud sync, no accounts. Tailory is a fully client-side application —
          there is no server, so your data cannot reach one.
        </p>
      </div>
    </div>

    <!-- Footer -->
    <footer class="mx-auto flex max-w-6xl items-center justify-between px-8 py-10">
      <p class="text-sm text-[#1e2438]">© 2025 Tailory — MIT licensed</p>
      <nav class="flex gap-8 text-sm">
        <a href="/features" class="text-[#3a4460] transition-colors hover:text-[#e2d0a8]"
          >Features</a
        >
        <a href="/about" class="text-[#3a4460] transition-colors hover:text-[#e2d0a8]">About</a>
        <a href="/faq" class="text-[#3a4460] transition-colors hover:text-[#e2d0a8]">FAQ</a>
      </nav>
    </footer>
  </div>
</Layout>
