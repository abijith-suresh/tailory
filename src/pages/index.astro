---
import Layout from "@/layouts/Layout.astro";
import FileUpload from "@/components/upload/FileUpload";
---

<Layout
  title="Tailory — Client-side Resume Editor"
  description="Upload a PDF or DOCX resume, edit it in a structured form, and export an ATS-safe PDF — all in your browser."
>
  <div class="min-h-screen bg-gradient-to-br from-indigo-950 via-gray-950 to-gray-900 text-white">
    <!-- Nav -->
    <header class="sticky top-0 z-50 border-b border-white/10 bg-gray-950/80 backdrop-blur-xl">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
        <span class="text-lg font-semibold tracking-tight text-indigo-300">Tailory</span>
        <a
          href="https://github.com/abijith-suresh/tailory"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-gray-400 transition-colors hover:text-white"
        >
          GitHub
        </a>
      </nav>
    </header>

    <main class="mx-auto max-w-3xl px-6 py-20">
      <!-- Hero -->
      <div class="mb-16 text-center">
        <h1 class="mb-4 text-5xl font-bold tracking-tight">
          Your resume, <span class="text-indigo-400">your browser.</span>
        </h1>
        <p class="text-lg text-gray-400">
          Upload a PDF or DOCX. Edit in a structured form. Export an ATS-safe PDF. <br />
          No server. No account. No data leaves your device.
        </p>
      </div>

      <!-- Upload Island -->
      <FileUpload client:only="solid-js" />

      <!-- Feature pills -->
      <div class="mt-16 flex flex-wrap justify-center gap-3">
        {
          [
            "PDF & DOCX upload",
            "Auto-parsing",
            "Live preview",
            "3 templates",
            "ATS-safe export",
            "Draft storage",
          ].map((f) => (
            <span class="rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-sm text-gray-400">
              {f}
            </span>
          ))
        }
      </div>
    </main>
  </div>
</Layout>
