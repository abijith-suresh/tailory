---
import Button from "@/components/Button.astro";
import Layout from "@/layouts/Layout.astro";

type PillarIcon = "agent" | "gate" | "typescript";

const agenticPillars: Array<{ description: string; icon: PillarIcon; title: string }> = [
  {
    title: "AGENTS.md Built In",
    description:
      "Your AI coding agent reads project conventions on day one. No onboarding, no ambiguity.",
    icon: "agent",
  },
  {
    title: "Zero Ambiguity TypeScript",
    description:
      "Strict mode catches errors at compile time. Your agent writes code that compiles first time.",
    icon: "typescript",
  },
  {
    title: "Pre-commit Quality Gates",
    description: "Husky + commitlint + lint-staged enforce standards before any code reaches CI.",
    icon: "gate",
  },
];

const features = [
  {
    title: "TypeScript Strict",
    description: "Catch errors early. Strict mode enabled via astro/tsconfigs/strict.",
    icon: "TS",
  },
  {
    title: "Tailwind CSS v4",
    description: "CSS-first config with @theme. No tailwind.config file needed.",
    icon: "TW",
  },
  {
    title: "Vitest + Testing Library",
    description: "jsdom environment, globals enabled, and jest-dom matchers ready to go.",
    icon: "VT",
  },
  {
    title: "ESLint Flat Config",
    description: "Strict rules for Astro, TypeScript, and import sorting.",
    icon: "ES",
  },
  {
    title: "Prettier",
    description: "Consistent formatting with the Astro plugin. Runs on every save.",
    icon: "PR",
  },
  {
    title: "Husky + commitlint",
    description:
      "Pre-commit hooks enforce lint/format. Commit messages follow Conventional Commits.",
    icon: "GH",
  },
  {
    title: "GitHub Actions CI",
    description: "Type check, lint, format, test, and build on every push and PR.",
    icon: "CI",
  },
  {
    title: "Dependabot",
    description: "Weekly automated dependency updates grouped by ecosystem.",
    icon: "DB",
  },
  {
    title: "DevContainer",
    description: "One-click reproducible dev environment with all extensions pre-installed.",
    icon: "DC",
  },
];

const badges = [
  { label: "Astro 5" },
  { label: "Tailwind v4" },
  { label: "TypeScript" },
  { label: "Vitest" },
  { label: "Bun" },
  { label: "ESLint" },
];
---

<Layout
  title="Agentic Astro — The AI-Ready Astro Starter"
  description="The Astro 5 starter built for AI-assisted development. AGENTS.md pre-wired. TypeScript strict. Linting, testing, and CI/CD ready from day one."
>
  <div class="min-h-screen bg-zinc-950 text-white">
    <!-- Nav -->
    <header class="sticky top-0 z-50 border-b border-zinc-800/60 bg-zinc-950/80 backdrop-blur-xl">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
        <span class="text-lg font-semibold tracking-tight">Agentic Astro</span>
        <div class="flex items-center gap-3">
          <a
            href="https://github.com/abijith-suresh/agentic-astro"
            target="_blank"
            rel="noopener noreferrer"
            class="hidden items-center gap-1.5 text-sm text-zinc-400 transition-colors hover:text-white sm:flex"
            aria-label="View on GitHub"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            GitHub
          </a>
          <a
            href="https://github.com/abijith-suresh/agentic-astro"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white transition-colors hover:bg-indigo-500"
          >
            Use Template
          </a>
        </div>
      </nav>
    </header>

    <main>
      <!-- Hero -->
      <section class="hero-section relative overflow-hidden px-6 pb-24 pt-20">
        <div class="mx-auto max-w-6xl">
          <!-- Overline badge -->
          <div class="mb-8 flex justify-center">
            <span
              class="inline-flex items-center gap-2 rounded-full border border-zinc-800 bg-zinc-900/80 px-4 py-1.5 text-xs text-zinc-400"
            >
              <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-400"></span>
              Built for Claude Code · Cursor · Copilot
            </span>
          </div>

          <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20">
            <!-- Left: Text content -->
            <div class="text-center lg:text-left">
              <h1
                class="mb-6 text-4xl font-semibold leading-none tracking-tight sm:text-5xl lg:text-6xl"
              >
                The Astro Starter
                <br />
                <span class="text-indigo-400">Built for AI</span>
              </h1>
              <p class="mb-8 max-w-lg text-base leading-relaxed text-zinc-400 sm:text-lg">
                AGENTS.md pre-wired. TypeScript strict. Linting, testing, and CI/CD ready from day
                one. Your AI coding agent hits the ground running.
              </p>
              <div class="mb-10 flex flex-wrap justify-center gap-4 lg:justify-start">
                <Button
                  href="https://github.com/abijith-suresh/agentic-astro"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Use This Template
                </Button>
                <Button
                  href="https://github.com/abijith-suresh/agentic-astro/blob/main/AGENTS.md"
                  variant="outline"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Read the Docs
                </Button>
              </div>
              <!-- Tech badges -->
              <div class="flex flex-wrap justify-center gap-2 lg:justify-start">
                {
                  badges.map(({ label }) => (
                    <span class="rounded-full border border-zinc-800 bg-zinc-900/60 px-3 py-1 text-xs font-medium text-zinc-400">
                      {label}
                    </span>
                  ))
                }
              </div>
            </div>

            <!-- Right: Terminal visual -->
            <div>
              <div
                class="rounded-xl border border-zinc-700/60 bg-zinc-900/90 shadow-2xl shadow-black/40"
              >
                <!-- Traffic lights bar -->
                <div class="flex items-center gap-2 border-b border-zinc-800/80 px-4 py-3">
                  <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
                  <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
                  <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
                  <span class="ml-auto font-mono text-xs text-zinc-600">AGENTS.md</span>
                </div>
                <!-- Content -->
                <div class="space-y-0.5 p-5 font-mono text-sm leading-7">
                  <p class="text-indigo-400"># Agentic Astro — Agent Instructions</p>
                  <p>&nbsp;</p>
                  <p class="text-zinc-500">## Stack</p>
                  <p class="text-zinc-300">
                    - Astro <span class="text-zinc-300">5</span> + Tailwind CSS
                    <span class="text-zinc-300">v4</span>
                  </p>
                  <p class="text-zinc-300">
                    - TypeScript <span class="text-zinc-300">strict</span> + Vitest
                  </p>
                  <p>&nbsp;</p>
                  <p class="text-zinc-500">## Commands</p>
                  <p class="text-zinc-300">
                    <span class="text-green-400">bun dev</span>
                    <span class="text-zinc-600"> → start dev server</span>
                  </p>
                  <p class="text-zinc-300">
                    <span class="text-green-400">bun run test</span>
                    <span class="text-zinc-600"> → run test suite</span>
                  </p>
                  <p>&nbsp;</p>
                  <p class="text-zinc-500">## Conventions</p>
                  <p class="text-zinc-300">
                    - Commits: <span class="text-zinc-300">Conventional Commits</span>
                  </p>
                  <p class="text-zinc-300">
                    - Imports: <span class="text-zinc-300">sorted alphabetically</span>
                  </p>
                  <p>&nbsp;</p>
                  <div class="flex items-center gap-2 pt-1">
                    <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
                    <span class="text-xs text-zinc-400">Agent context loaded</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Why Agentic -->
      <section class="border-y border-zinc-800/60 px-6 py-24">
        <div class="mx-auto max-w-6xl">
          <div class="mb-14 text-center">
            <h2 class="mb-3 text-2xl font-semibold tracking-tight sm:text-3xl">Why Agentic?</h2>
            <p class="text-zinc-400">The conventions your AI agent needs, ready on first clone.</p>
          </div>
          <div class="grid gap-6 sm:grid-cols-3">
            {
              agenticPillars.map(({ description, icon, title }) => (
                <div class="group rounded-xl border border-zinc-800 bg-zinc-900/40 p-8 transition-all hover:border-zinc-700 hover:bg-zinc-900/70">
                  <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-lg border border-zinc-700 bg-zinc-800 text-indigo-400 transition-all group-hover:border-indigo-700/60 group-hover:bg-indigo-950/50">
                    {icon === "agent" && (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <rect x="3" y="11" width="18" height="11" rx="2" />
                        <circle cx="12" cy="5" r="2" />
                        <line x1="12" y1="7" x2="12" y2="11" />
                        <circle cx="8" cy="17" r="1.5" fill="currentColor" stroke="none" />
                        <circle cx="16" cy="17" r="1.5" fill="currentColor" stroke="none" />
                      </svg>
                    )}
                    {icon === "typescript" && (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        <polyline points="9 12 11 14 15 10" />
                      </svg>
                    )}
                    {icon === "gate" && (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <rect x="5" y="11" width="14" height="11" rx="2" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                      </svg>
                    )}
                  </div>
                  <h3 class="mb-2 font-semibold text-white">{title}</h3>
                  <p class="text-sm leading-relaxed text-zinc-500">{description}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- What's Included -->
      <section class="px-6 py-24">
        <div class="mx-auto max-w-6xl">
          <div class="mb-14 text-center">
            <h2 class="mb-3 text-2xl font-semibold tracking-tight sm:text-3xl">What's Included</h2>
            <p class="text-zinc-400">Everything you need to ship. Nothing you don't.</p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {
              features.map(({ description, icon, title }) => (
                <div class="rounded-xl border border-zinc-800 bg-zinc-900/50 p-6 transition-colors hover:border-zinc-700">
                  <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-lg bg-zinc-800 font-mono text-xs font-bold text-zinc-300">
                    {icon}
                  </div>
                  <h3 class="mb-1 font-semibold">{title}</h3>
                  <p class="text-sm text-zinc-500">{description}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- Quick Start -->
      <section class="border-t border-zinc-800/60 px-6 py-24">
        <div class="mx-auto max-w-4xl">
          <div class="mb-14 text-center">
            <h2 class="mb-3 text-2xl font-semibold tracking-tight sm:text-3xl">Quick Start</h2>
            <p class="text-zinc-400">Up and running in under a minute.</p>
          </div>
          <div class="grid gap-10 sm:grid-cols-3">
            <div class="group flex flex-col">
              <div
                class="mb-4 font-mono text-5xl font-bold text-zinc-800 transition-colors group-hover:text-indigo-900/80"
              >
                01
              </div>
              <h3 class="mb-2 font-semibold">Use the template</h3>
              <p class="mb-4 text-sm leading-relaxed text-zinc-500">
                Click "Use This Template" on GitHub to create your repo instantly.
              </p>
              <div
                class="mt-auto truncate rounded-lg border border-zinc-800 bg-zinc-900 px-3 py-2 font-mono text-xs text-zinc-500"
              >
                github.com/abijith-suresh/agentic-astro
              </div>
            </div>
            <div class="group flex flex-col">
              <div
                class="mb-4 font-mono text-5xl font-bold text-zinc-800 transition-colors group-hover:text-indigo-900/80"
              >
                02
              </div>
              <h3 class="mb-2 font-semibold">Install dependencies</h3>
              <p class="mb-4 text-sm leading-relaxed text-zinc-500">
                Bun installs everything in seconds, including all dev tooling.
              </p>
              <div
                class="mt-auto rounded-lg border border-zinc-800 bg-zinc-900 px-3 py-2 font-mono text-xs text-green-400"
              >
                $ bun install
              </div>
            </div>
            <div class="group flex flex-col">
              <div
                class="mb-4 font-mono text-5xl font-bold text-zinc-800 transition-colors group-hover:text-indigo-900/80"
              >
                03
              </div>
              <h3 class="mb-2 font-semibold">Start building</h3>
              <p class="mb-4 text-sm leading-relaxed text-zinc-500">
                Dev server starts at localhost:4321 with HMR and Astro islands ready.
              </p>
              <div
                class="mt-auto rounded-lg border border-zinc-800 bg-zinc-900 px-3 py-2 font-mono text-xs text-green-400"
              >
                $ bun dev
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Footer CTA -->
      <section class="px-6 py-32">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="mb-4 text-3xl font-semibold tracking-tight sm:text-4xl">
            Start your next project
            <br />
            <span class="text-indigo-400">the agentic way.</span>
          </h2>
          <p class="mb-10 text-zinc-500">Open source · MIT license · No lock-in</p>
          <Button
            href="https://github.com/abijith-suresh/agentic-astro"
            target="_blank"
            rel="noopener noreferrer"
          >
            Use This Template on GitHub
          </Button>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="border-t border-zinc-800/60 px-6 py-8">
      <div
        class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 text-sm text-zinc-600 sm:flex-row"
      >
        <span>
          Built with
          <a
            href="https://astro.build"
            target="_blank"
            rel="noopener noreferrer"
            class="text-zinc-500 transition-colors hover:text-white"
          >
            Astro
          </a>
          and
          <a
            href="https://tailwindcss.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-zinc-500 transition-colors hover:text-white"
          >
            Tailwind CSS
          </a>
        </span>
        <a
          href="https://github.com/abijith-suresh/agentic-astro"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-zinc-400"
        >
          abijith-suresh/agentic-astro
        </a>
      </div>
    </footer>
  </div>
</Layout>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .hero-section {
    animation: fade-in 0.4s ease-out both;
  }
</style>
