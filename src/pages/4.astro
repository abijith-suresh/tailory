---
import Layout from "@/layouts/Layout.astro";

const col1Features = [
  {
    name: "PDF & DOCX Upload",
    desc: "Drop any resume format — Tailory extracts the text entirely in your browser, with no upload to any server.",
  },
  {
    name: "Auto-Parsing",
    desc: "Heuristic section detection maps raw extracted text into structured JSON Resume fields automatically.",
  },
  {
    name: "Live Preview",
    desc: "See your resume rendered in real time alongside the editor. No save, no reload, no delay.",
  },
];

const col2Features = [
  {
    name: "Three Templates",
    desc: "Modern, Minimal, and Compact ATS — switch between them instantly in the live preview panel.",
  },
  {
    name: "ATS-Safe Export",
    desc: "pdfmake generates machine-readable PDFs with no images or tables — compatible with every major ATS.",
  },
  {
    name: "Draft Storage",
    desc: "Auto-saved to IndexedDB in your browser. Your work persists across sessions, locally.",
  },
];

const steps = [
  {
    n: "1.",
    title: "Upload your resume",
    desc: "Drop a PDF or DOCX file — or start from a blank form. Text extraction runs immediately, in your browser.",
  },
  {
    n: "2.",
    title: "Edit every field",
    desc: "Work through each section in a structured editor. See the live preview update as you type.",
  },
  {
    n: "3.",
    title: "Export your PDF",
    desc: "Download an ATS-optimised PDF in one click. Ready to submit anywhere, immediately.",
  },
];
---

<Layout
  title="Tailory — Broadsheet"
  description="A fully client-side resume editor. No server, no account, no data leaves your device."
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Source+Sans+3:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div
    class="min-h-screen bg-[#f7f5f0] text-[#1a1410]"
    style="font-family: 'Source Sans 3', system-ui, sans-serif"
  >
    <!-- Nav — masthead style -->
    <header class="border-b-4 border-[#1a1410]">
      <div class="mx-auto max-w-6xl px-8">
        <div class="flex items-center justify-between py-4">
          <span
            class="text-3xl font-bold uppercase tracking-widest text-[#1a1410]"
            style="font-family: 'Libre Baskerville', Georgia, serif; letter-spacing: 0.15em"
          >
            Tailory
          </span>
          <div class="flex items-center gap-8 text-sm text-[#6b5e52]">
            <span class="hidden md:block">Vol. I · Est. 2025</span>
            <a
              href="https://github.com/abijith-suresh/tailory"
              target="_blank"
              rel="noopener noreferrer"
              class="transition-colors hover:text-[#b32c1e]"
            >
              GitHub ↗
            </a>
          </div>
        </div>
        <div
          class="border-t border-[#c8bfb0] py-2 text-center text-xs uppercase tracking-[0.2em] text-[#6b5e52]"
        >
          Client-side resume editor · No account · No data leaves your browser
        </div>
      </div>
    </header>

    <!-- Hero — newspaper front page -->
    <section class="mx-auto max-w-6xl px-8 py-16">
      <h1
        class="mb-6 leading-[0.88] tracking-tight text-[#1a1410]"
        style="font-family: 'Libre Baskerville', Georgia, serif; font-size: clamp(52px, 9vw, 112px); font-weight: 700"
      >
        The resume editor<br />
        <span style="color: #b32c1e">that works for you,</span><br />
        not against you.
      </h1>
      <!-- Thick rule -->
      <div class="mb-8 h-1 w-full bg-[#1a1410]"></div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        <div class="md:col-span-2">
          <p class="text-xl leading-relaxed text-[#3a2e24]">
            Tailory is a fully client-side resume editor. Upload a PDF or DOCX, edit every field in
            a structured form, preview live, and export an ATS-safe PDF — all in your browser.
            Nothing leaves your device.
          </p>
        </div>
        <div class="flex items-start md:justify-end">
          <a
            href="/editor"
            class="inline-block border-2 border-[#b32c1e] bg-[#b32c1e] px-8 py-3 text-base font-semibold text-[#f7f5f0] transition-all hover:bg-transparent hover:text-[#b32c1e]"
            style="font-family: 'Libre Baskerville', Georgia, serif"
          >
            Open the editor →
          </a>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="mx-auto max-w-6xl border-t border-[#c8bfb0] px-8"></div>

    <!-- Features — 2-column newspaper layout -->
    <section class="mx-auto max-w-6xl px-8 py-20">
      <h2
        class="mb-8 text-xs uppercase tracking-[0.25em] text-[#b32c1e]"
        style="font-family: 'Libre Baskerville', Georgia, serif"
      >
        Features
      </h2>
      <div class="grid grid-cols-1 gap-x-16 md:grid-cols-2">
        <!-- Column 1 -->
        <div class="space-y-0">
          {
            col1Features.map((f) => (
              <div class="border-t border-[#c8bfb0] py-7">
                <h3
                  class="mb-3 text-xl font-bold text-[#1a1410]"
                  style="font-family: 'Libre Baskerville', Georgia, serif"
                >
                  {f.name}
                </h3>
                <p class="text-base leading-relaxed text-[#6b5e52]">{f.desc}</p>
              </div>
            ))
          }
        </div>
        <!-- Column 2 -->
        <div class="space-y-0">
          {
            col2Features.map((f) => (
              <div class="border-t border-[#c8bfb0] py-7">
                <h3
                  class="mb-3 text-xl font-bold text-[#1a1410]"
                  style="font-family: 'Libre Baskerville', Georgia, serif"
                >
                  {f.name}
                </h3>
                <p class="text-base leading-relaxed text-[#6b5e52]">{f.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="mx-auto max-w-6xl border-t-2 border-[#1a1410] px-8"></div>

    <!-- How it works -->
    <section class="mx-auto max-w-6xl px-8 py-20">
      <h2
        class="mb-12 text-xs uppercase tracking-[0.25em] text-[#b32c1e]"
        style="font-family: 'Libre Baskerville', Georgia, serif"
      >
        How it works
      </h2>
      <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
        {
          steps.map((s) => (
            <div class="border-t-2 border-[#1a1410] pt-6">
              <p
                class="mb-4 text-4xl font-bold text-[#b32c1e]"
                style="font-family: 'Libre Baskerville', Georgia, serif"
              >
                {s.n}
              </p>
              <h3
                class="mb-3 text-xl font-bold text-[#1a1410]"
                style="font-family: 'Libre Baskerville', Georgia, serif"
              >
                {s.title}
              </h3>
              <p class="text-base leading-relaxed text-[#6b5e52]">{s.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Privacy callout — dramatic inversion -->
    <div class="bg-[#1a1410]">
      <div class="mx-auto max-w-6xl px-8 py-20">
        <div class="grid grid-cols-1 gap-10 md:grid-cols-2 md:items-center">
          <h2
            class="leading-tight text-[#f7f5f0]"
            style="font-family: 'Libre Baskerville', Georgia, serif; font-size: clamp(28px, 3.5vw, 48px); font-weight: 700"
          >
            Your data never leaves your device.
          </h2>
          <p class="text-lg leading-relaxed text-[#8a7a6e]">
            No telemetry. No cloud sync. No account required. Tailory is a fully client-side
            application — there is no server, so your resume data cannot reach one.
          </p>
        </div>
      </div>
    </div>

    <!-- Footer — newspaper dateline style -->
    <footer class="border-t-4 border-[#1a1410]">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-8 py-8">
        <p class="text-sm text-[#6b5e52]" style="font-family: 'Libre Baskerville', Georgia, serif">
          © 2025 Tailory · MIT License
        </p>
        <nav class="flex gap-8 text-sm text-[#6b5e52]">
          <a href="/features" class="transition-colors hover:text-[#b32c1e]">Features</a>
          <a href="/about" class="transition-colors hover:text-[#b32c1e]">About</a>
          <a href="/faq" class="transition-colors hover:text-[#b32c1e]">FAQ</a>
        </nav>
      </div>
    </footer>
  </div>
</Layout>
