---
import Layout from "@/layouts/Layout.astro";

const features = [
  {
    name: "PDF & DOCX Upload",
    desc: "Drop any resume format — Tailory extracts the text entirely in your browser.",
  },
  {
    name: "Auto-Parsing",
    desc: "Heuristic parsing maps raw text into structured JSON Resume fields automatically.",
  },
  {
    name: "Live Preview",
    desc: "See your resume rendered in real time as you make edits — no reload needed.",
  },
  {
    name: "Three Templates",
    desc: "Modern, Minimal, and Compact ATS — each optimised for different contexts.",
  },
  {
    name: "ATS-Safe Export",
    desc: "Machine-readable PDFs with no images or tables to confuse applicant systems.",
  },
  {
    name: "Draft Storage",
    desc: "Auto-saved to your browser's IndexedDB — never to any server.",
  },
];

const chips = ["100% client-side", "No account required", "Open source · MIT"];

const steps = [
  {
    title: "Upload",
    desc: "Drop your existing PDF or DOCX resume, or begin from a blank form. Extraction happens instantly, locally.",
  },
  {
    title: "Edit",
    desc: "Refine every field in a structured editor. Basics, work history, education, skills — everything in one place.",
  },
  {
    title: "Export",
    desc: "Download a polished, ATS-compatible PDF in one click. No account, no watermark, no friction.",
  },
];
---

<Layout
  title="Tailory — Aperture"
  description="A fully client-side resume editor. No server, no account, no data leaves your device."
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@1,9..144,400;1,9..144,700&family=Instrument+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div
    class="min-h-screen bg-[#070d1a] text-[#c8d4e8]"
    style="font-family: 'Instrument Sans', system-ui, sans-serif"
  >
    <!-- Nav -->
    <header class="border-b border-[#101828]">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-8 py-5">
        <span
          class="text-2xl font-bold text-[#e8604a]"
          style="font-family: 'Fraunces', Georgia, serif; font-style: italic"
        >
          Tailory
        </span>
        <a
          href="https://github.com/abijith-suresh/tailory"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-[#4a5878] transition-colors hover:text-[#e8604a]"
        >
          GitHub ↗
        </a>
      </nav>
    </header>

    <!-- Hero — centered, large italic Fraunces -->
    <section class="mx-auto max-w-5xl px-8 pb-24 pt-28 text-center">
      <h1
        class="mx-auto mb-8 max-w-3xl leading-[0.95] text-[#e8f0ff]"
        style="font-family: 'Fraunces', Georgia, serif; font-size: clamp(58px, 8vw, 96px); font-style: italic; font-weight: 700"
      >
        Your resume editor.<br />
        <span style="color: #e8604a">No strings attached.</span>
      </h1>
      <p class="mx-auto mb-10 max-w-lg text-lg leading-relaxed text-[#4a5878]">
        Upload a PDF or DOCX, edit every field, preview live, export an ATS-safe PDF. All in your
        browser. Nothing leaves your device.
      </p>

      <!-- Trust chips -->
      <div class="mb-10 flex flex-wrap justify-center gap-3">
        {
          chips.map((chip) => (
            <span class="rounded-full border border-[#1a2438] px-4 py-1.5 text-xs font-medium tracking-wide text-[#4a5878]">
              {chip}
            </span>
          ))
        }
      </div>

      <a
        href="/editor"
        class="inline-block bg-[#e8604a] px-8 py-3.5 text-sm font-semibold text-[#070d1a] transition-opacity hover:opacity-90"
      >
        Open the editor →
      </a>
    </section>

    <!-- Features grid with coral top border -->
    <section class="border-t border-[#101828]">
      <div class="mx-auto max-w-5xl px-8 py-24">
        <p class="mb-16 text-xs uppercase tracking-[0.2em] text-[#4a5878]">What it does</p>
        <div class="grid grid-cols-1 gap-x-12 gap-y-0 md:grid-cols-2">
          {
            features.map((f) => (
              <div class="border-b border-[#101828] py-8 first:border-t md:[&:nth-child(2)]:border-t">
                <div class="mb-3 h-0.5 w-8 bg-[#e8604a]" />
                <h3 class="mb-2 text-base font-semibold text-[#c8d4e8]">{f.name}</h3>
                <p class="text-sm leading-relaxed text-[#4a5878]">{f.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="border-t border-[#101828]">
      <div class="mx-auto max-w-5xl px-8 py-24">
        <p class="mb-16 text-xs uppercase tracking-[0.2em] text-[#4a5878]">How it works</p>
        <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
          {
            steps.map((s, i) => (
              <div>
                <p
                  class="mb-4 leading-none text-[#101828]"
                  style="font-family: 'Fraunces', Georgia, serif; font-size: 4rem; font-style: italic; font-weight: 700"
                >
                  0{i + 1}
                </p>
                <h3 class="mb-3 text-lg font-semibold text-[#c8d4e8]">{s.title}</h3>
                <p class="text-sm leading-relaxed text-[#4a5878]">{s.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Privacy callout -->
    <div class="border-y border-[#101828] bg-[#050a12]">
      <div class="mx-auto max-w-5xl px-8 py-20">
        <div class="flex flex-col gap-10 md:flex-row md:items-center md:justify-between">
          <h2
            class="max-w-lg leading-tight text-[#e8f0ff]"
            style="font-family: 'Fraunces', Georgia, serif; font-size: clamp(28px, 3.5vw, 44px); font-style: italic"
          >
            Your data never leaves your device.
          </h2>
          <p class="max-w-sm text-base leading-relaxed text-[#4a5878]">
            No telemetry. No cloud sync. No accounts. Tailory runs entirely in your browser — there
            is no server to send your resume to.
          </p>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="mx-auto flex max-w-5xl items-center justify-between px-8 py-10">
      <p class="text-sm text-[#1a2438]">© 2025 Tailory — MIT licensed</p>
      <nav class="flex gap-8 text-sm">
        <a href="/features" class="text-[#4a5878] transition-colors hover:text-[#e8604a]"
          >Features</a
        >
        <a href="/about" class="text-[#4a5878] transition-colors hover:text-[#e8604a]">About</a>
        <a href="/faq" class="text-[#4a5878] transition-colors hover:text-[#e8604a]">FAQ</a>
      </nav>
    </footer>
  </div>
</Layout>
