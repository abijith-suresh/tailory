---
import Layout from "@/layouts/Layout.astro";

const features = [
  {
    term: "PDF & DOCX Upload",
    def: "Drop any resume format — Tailory handles the text extraction entirely in your browser.",
  },
  {
    term: "Auto-Parsing",
    def: "Heuristic parsing maps raw text into structured JSON Resume fields automatically.",
  },
  {
    term: "Live Preview",
    def: "See your resume rendered in real time as you make edits — no save required.",
  },
  {
    term: "Three Templates",
    def: "Modern, Minimal, and Compact ATS — each optimised for a different context.",
  },
  {
    term: "ATS-Safe Export",
    def: "Machine-readable PDFs with no images or tables to confuse applicant tracking systems.",
  },
  {
    term: "Draft Storage",
    def: "Your work saves automatically to your browser's IndexedDB — never to a server.",
  },
];

const steps = [
  {
    n: "I",
    title: "Upload",
    desc: "Drop your existing PDF or DOCX resume, or begin from a blank form.",
  },
  {
    n: "II",
    title: "Edit",
    desc: "Refine every field in a structured editor. No formatting fights, no surprises.",
  },
  {
    n: "III",
    title: "Export",
    desc: "Download a polished, ATS-compatible PDF in one click.",
  },
];
---

<Layout
  title="Tailory — Inkwell"
  description="A fully client-side resume editor. No server, no account, no data leaves your device."
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;700&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div
    class="min-h-screen bg-[#110c08] text-[#c9b89a]"
    style="font-family: 'Crimson Pro', Georgia, serif"
  >
    <!-- Nav -->
    <header class="border-b border-[#2a1c0d]">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-8 py-5">
        <span
          class="text-2xl font-bold tracking-tight text-[#c4913a]"
          style="font-family: 'Cormorant Garamond', Georgia, serif"
        >
          Tailory
        </span>
        <a
          href="https://github.com/abijith-suresh/tailory"
          target="_blank"
          rel="noopener noreferrer"
          class="text-base text-[#6b4f35] transition-colors hover:text-[#c4913a]"
        >
          GitHub ↗
        </a>
      </nav>
    </header>

    <!-- Hero -->
    <section class="mx-auto max-w-6xl px-8 pb-20 pt-24">
      <p class="mb-10 text-xs uppercase tracking-[0.25em] text-[#6b4f35]">
        Client-side resume editor
      </p>
      <h1
        class="mb-6 max-w-4xl leading-[0.95] tracking-tight text-[#e8d8bc]"
        style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(64px, 8vw, 100px); font-weight: 700"
      >
        The resume editor<br />that belongs<br />
        <em style="color: #c4913a">to you alone.</em>
      </h1>
      <!-- Gold rule -->
      <div class="mb-10 h-px w-24 bg-[#c4913a]"></div>
      <p class="mb-10 max-w-lg text-xl leading-relaxed text-[#8a6e52]">
        No server. No account. No data leaves your device. Upload a PDF or DOCX, edit in a
        structured form, export an ATS-safe PDF — entirely in your browser.
      </p>
      <a
        href="/editor"
        class="inline-block border border-[#c4913a] px-8 py-3 text-base tracking-wide text-[#c4913a] transition-all hover:bg-[#c4913a] hover:text-[#110c08]"
      >
        Open the editor →
      </a>
    </section>

    <!-- Divider -->
    <div class="mx-auto max-w-6xl border-t border-[#2a1c0d] px-8"></div>

    <!-- Features — definition list layout -->
    <section class="mx-auto max-w-6xl px-8 py-24">
      <p class="mb-16 text-xs uppercase tracking-[0.25em] text-[#6b4f35]">What it does</p>
      <dl class="grid grid-cols-1 gap-x-20 gap-y-10 md:grid-cols-2">
        {
          features.map((f) => (
            <div class="border-t border-[#2a1c0d] pt-6">
              <dt
                class="mb-2 text-xl font-semibold text-[#c9b89a]"
                style="font-family: 'Cormorant Garamond', Georgia, serif"
              >
                {f.term}
              </dt>
              <dd class="text-base leading-relaxed text-[#6b4f35]">{f.def}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    <!-- Divider -->
    <div class="mx-auto max-w-6xl border-t border-[#2a1c0d] px-8"></div>

    <!-- How it works -->
    <section class="mx-auto max-w-6xl px-8 py-24">
      <p class="mb-16 text-xs uppercase tracking-[0.25em] text-[#6b4f35]">How it works</p>
      <div class="grid grid-cols-1 gap-16 md:grid-cols-3">
        {
          steps.map((s) => (
            <div>
              <p
                class="mb-5 leading-none text-[#2a1c0d]"
                style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 5rem; font-weight: 700"
              >
                {s.n}
              </p>
              <h3
                class="mb-3 text-2xl font-semibold text-[#c9b89a]"
                style="font-family: 'Cormorant Garamond', Georgia, serif"
              >
                {s.title}
              </h3>
              <p class="text-base leading-relaxed text-[#6b4f35]">{s.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Privacy callout -->
    <div class="border-b border-t border-[#2a1c0d]">
      <div class="mx-auto max-w-6xl px-8 py-20">
        <p class="mb-4 text-xs uppercase tracking-[0.25em] text-[#6b4f35]">Privacy</p>
        <h2
          class="mb-5 max-w-3xl leading-tight text-[#e8d8bc]"
          style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(32px, 4vw, 52px); font-weight: 700"
        >
          Your resume is your business. We have no way of seeing it.
        </h2>
        <p class="max-w-lg text-lg leading-relaxed text-[#6b4f35]">
          No telemetry. No cloud sync. No accounts required. Tailory runs entirely in your browser —
          your data stays exactly where it belongs.
        </p>
      </div>
    </div>

    <!-- Footer -->
    <footer class="mx-auto flex max-w-6xl items-center justify-between px-8 py-10">
      <p class="text-sm text-[#3a2618]">© 2025 Tailory — MIT licensed</p>
      <nav class="flex gap-8 text-sm">
        <a href="/features" class="text-[#6b4f35] transition-colors hover:text-[#c4913a]"
          >Features</a
        >
        <a href="/about" class="text-[#6b4f35] transition-colors hover:text-[#c4913a]">About</a>
        <a href="/faq" class="text-[#6b4f35] transition-colors hover:text-[#c4913a]">FAQ</a>
      </nav>
    </footer>
  </div>
</Layout>
